# Database
DB_NAME=threatmapper
DB_USER=tm_user
DB_PASS=changeme_strong_password

# AI Provider Keys (at least one required for analysis features)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ATT&CK Domains to ingest (comma-separated, no spaces)
# Options: enterprise-attack, mobile-attack, ics-attack
ATTCK_DOMAINS=enterprise-attack,mobile-attack,ics-attack

# Logging: debug, info, warning, error
LOG_LEVEL=info

# Optional team authentication behind an OIDC-aware reverse proxy.
# The proxy must set X-Auth-User and X-Auth-Roles (admin, analyst, or viewer).
AUTH_ENABLED=false
AUTH_DEFAULT_ROLE=admin

# Autonomous Anomaly Detection Atlas synchronization
ATLAS_REPOSITORY=https://github.com/anpa1200/anomaly-detection-atlas.git
ATLAS_SYNC_INTERVAL=3600
REFERENCE_URL=http://localhost:3001/anomaly-detection-atlas
